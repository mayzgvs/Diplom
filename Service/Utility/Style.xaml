        <Setter Property="Margin" Value="5"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ComboBox x:Name="PART_ComboBox"
                                  ItemsSource="{TemplateBinding ItemsSource}"
                                  SelectedValue="{TemplateBinding SelectedValue}"
                                  SelectedValuePath="{TemplateBinding SelectedValuePath}"
                                  DisplayMemberPath="{TemplateBinding DisplayMemberPath}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Background="{TemplateBinding Background}"
                                  Padding="{TemplateBinding Padding}"
                                  FontSize="{TemplateBinding FontSize}"
                                  Height="{TemplateBinding Height}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        <TextBlock x:Name="Watermark"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="#999999"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Padding="{TemplateBinding Padding}"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_ComboBox" Property="SelectedValue" Value="{x:Null}">
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger SourceName="PART_ComboBox" Property="SelectedValue" Value="">
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger SourceName="PART_ComboBox" Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Watermark" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
