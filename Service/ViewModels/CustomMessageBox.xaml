<Window x:Class="Service.Views.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сообщение"
        Width="480"
        MinWidth="400"
        MaxWidth="800"
        MinHeight="200"
        MaxHeight="600"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Тень для окна -->
        <DropShadowEffect x:Key="WindowShadow" 
                          BlurRadius="25" 
                          Opacity="0.12" 
                          ShadowDepth="2"
                          Color="#000000"/>

        <!-- Единый стиль для всех кнопок (синий) -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A3F54"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A252F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F1A24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для вторичной кнопки (синяя обводка) -->
        <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2A3F54"/>
            <Setter Property="BorderBrush" Value="#2A3F54"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="22,8"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F0FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки закрытия (без красного) -->
        <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Content" Value="✕"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#2A3F54"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Иконки типов сообщений (монохромные) -->
        <Geometry x:Key="InfoIcon">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z</Geometry>
        <Geometry x:Key="SuccessIcon">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z</Geometry>
        <Geometry x:Key="WarningIcon">M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z</Geometry>
        <Geometry x:Key="ErrorIcon">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z</Geometry>
        <Geometry x:Key="QuestionIcon">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2-7h-1.5c.9-.8 1.5-2 1.5-3.5 0-2.5-2-4.5-4.5-4.5S8 6 8 8.5h2c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5c0 1.4-1.1 2.5-2.5 2.5H11v3h2v-2z</Geometry>
    </Window.Resources>

    <Border Background="Transparent">
        <Border Background="White" 
                CornerRadius="16" 
                Effect="{StaticResource WindowShadow}"
                BorderBrush="#E0E4E9"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Верхняя полоса -->
                <Border x:Name="HeaderBorder"
                        Grid.Row="0" 
                        CornerRadius="16,16,0,0"
                        Padding="24,18,16,18"
                        Background="#2A3F54">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="IconBorder"
                                Grid.Column="0"
                                Width="32"
                                Height="32"
                                CornerRadius="8"
                                Background="White"
                                Margin="0,0,14,0"
                                Opacity="0.95">
                            <Path x:Name="IconPath" 
                                  Width="18" 
                                  Height="18" 
                                  Fill="#2A3F54"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="txtTitle" 
                                   Grid.Column="1"
                                   Text="Сообщение"
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <Button x:Name="CloseButton"
                                Grid.Column="2"
                                Style="{StaticResource DialogCloseButtonStyle}" 
                                Click="CloseButton_Click"
                                Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Сообщение -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="28,24,28,20">
                        <TextBlock x:Name="txtMessage" 
                                   TextWrapping="Wrap" 
                                   FontSize="14" 
                                   FontFamily="Segoe UI"
                                   Foreground="#2C3E50"
                                   LineHeight="1.5"/>
                    </ScrollViewer>
                </Grid>

                <!-- Кнопки -->
                <Border Grid.Row="2" 
                        Background="#F8F9FA" 
                        CornerRadius="0,0,16,16"
                        Padding="24,16">
                    <StackPanel x:Name="ButtonsPanel" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"/>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>