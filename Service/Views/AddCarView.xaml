<Window x:Class="Service.Views.AddCarView"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление автомобиля" Height="496" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="15" Margin="5,5,5,10">
        <Grid Margin="0,0,0,43">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🚗" FontSize="22" Foreground="{StaticResource TealBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="Добавление автомобиля" FontSize="20" FontWeight="Light" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="30,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- добавили строку для пояснения -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Марка -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Марка <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <xctk:WatermarkTextBox Grid.Row="0" Grid.Column="1"
                                           Style="{StaticResource ModernWatermarkTextBox}"
                                           Text="{Binding EditingCar.Brand, UpdateSourceTrigger=PropertyChanged}"
                                           Watermark="Например: Toyota, BMW, Mercedes"/>

                    <!-- Модель -->
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Модель <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <xctk:WatermarkTextBox Grid.Row="1" Grid.Column="1"
                                           Style="{StaticResource ModernWatermarkTextBox}"
                                           Text="{Binding EditingCar.Model, UpdateSourceTrigger=PropertyChanged}"
                                           Watermark="Например: Camry, X5, C-Class"/>

                    <!-- Рег. номер -->
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Рег. номер <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <xctk:WatermarkTextBox Grid.Row="2" Grid.Column="1"
                                           Style="{StaticResource ModernWatermarkTextBox}"
                                           Text="{Binding EditingCar.RegistrationNumber, UpdateSourceTrigger=PropertyChanged}"
                                           Watermark="Формат: А123ВС 777"/>

                    <!-- VIN -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="VIN" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <xctk:WatermarkTextBox Grid.Row="3" Grid.Column="1"
                                           Style="{StaticResource ModernWatermarkTextBox}"
                                           Text="{Binding EditingCar.VIN, UpdateSourceTrigger=PropertyChanged}"
                                           Watermark="17 символов: JHMCM56557C404458"/>

                    <!-- Владелец -->
                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Владелец <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <Grid Grid.Row="4" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,5,5,5">
                            <ComboBox x:Name="OwnerComboBox"
                                      ItemsSource="{Binding Clients}"
                                      SelectedValue="{Binding EditingCar.OwnerId, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="FullName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Style="{StaticResource ModernComboBox}"/>
                        </Grid>
                        <Button Grid.Column="1"
                                Content="+"
                                Width="38"
                                Height="38"
                                Margin="8,5,5,5"
                                Command="{Binding AddNewClientCommand}"
                                Background="{StaticResource TealBrush}"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Добавить нового владельца"/>
                    </Grid>

                    <!-- Пояснение к звёздочкам -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                               Margin="5,15,5,5" 
                               FontSize="13" 
                               Foreground="#7F8C8E"
                               Text="* — обязательное для заполнения поле"/>

                </Grid>
            </ScrollViewer>

            <!-- Нижняя панель с кнопкой -->
            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}" CornerRadius="0,0,15,15" Padding="20,15" Margin="0,0,0,-44">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Height="38" Margin="5"
                            Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="{StaticResource TealBrush}"
                            Foreground="White"
                            FontSize="13"
                            Cursor="Hand"
                            ToolTip="Сохранить автомобиль"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>