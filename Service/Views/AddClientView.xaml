<Window x:Class="Service.Views.AddClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление клиента" Height="480" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="15" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👥" FontSize="24" Foreground="#3498DB" Margin="0,0,12,0"/>
                        <TextBlock Text="Добавление клиента"
                                   FontSize="22"
                                   FontWeight="Light"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}"
                                Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="White" Padding="30,25,30,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/> <!-- для пояснения -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Фамилия -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Style="{StaticResource FormLabelStyle}">
                        Фамилия 
                        <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.LastName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите фамилию (например: Иванов)"/>

                    <!-- Имя -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Style="{StaticResource FormLabelStyle}">
                        Имя 
                        <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите имя (например: Иван)"/>

                    <!-- Телефон -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Style="{StaticResource FormLabelStyle}">
                        Телефон 
                        <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.ContactNumber, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Формат: +7 (999) 123-45-67"/>

                    <!-- Email -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Email"
                               Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.Email, UpdateSourceTrigger=PropertyChanged}"
                             Tag="example@mail.ru"/>

                    <!-- Пояснение к звёздочкам -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                               Margin="5,20,5,5"
                               FontSize="13"
                               Foreground="#7F8C8E"
                               Text="* — обязательное для заполнения поле"/>

                </Grid>
            </ScrollViewer>

            <!-- Нижняя панель с кнопкой -->
            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}"
                    CornerRadius="0,0,15,15" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="110" Height="40" Margin="8,0"
                            Command="{Binding SaveCommand}"
                            Background="#3498DB"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            ToolTip="Сохранить клиента"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>