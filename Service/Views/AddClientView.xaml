<Window x:Class="Service.Views.AddClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление клиента" Height="480" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundBrush}" CornerRadius="15" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👥" FontSize="24" Foreground="#3498DB" Margin="0,0,12,0"/>
                        <TextBlock Text="Добавление клиента"
                                   FontSize="22"
                                   FontWeight="Light"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}"
                                Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="White" Padding="30,25,30,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Фамилия"
                               Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.LastName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите фамилию (например: Иванов)"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Имя"
                               Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите имя (например: Иван)"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Телефон"
                               Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.ContactNumber, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Формат: +7 (999) 123-45-67"/>

                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Email"
                               Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxBlue}"
                             Text="{Binding EditingClient.Email, UpdateSourceTrigger=PropertyChanged}"
                             Tag="example@mail.ru"/>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}"
                    CornerRadius="0,0,15,15" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="110" Height="40" Margin="8,0"
                            Command="{Binding SaveCommand}"
                            Background="#3498DB"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>