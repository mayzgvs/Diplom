<Window x:Class="Service.Views.AddClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление клиента" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Фамилия -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="0" Grid.Column="1" 
                 Text="{Binding EditingClient.LastName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" Height="30"/>

        <!-- Имя -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding EditingClient.FirstName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" Height="30"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="2" Grid.Column="1" 
                 Text="{Binding EditingClient.ContactNumber, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" Height="30"/>

        <!-- Скидка -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Скидка (%):" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="3" Grid.Column="1" 
                 Text="{Binding EditingClient.Discount, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" Height="30"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Сохранить" Width="80" Height="35" Margin="5"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Отмена" Width="80" Height="35" Margin="5"
                    Command="{Binding CancelEditCommand}"/>
        </StackPanel>
    </Grid>
</Window>