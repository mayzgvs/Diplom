<Window x:Class="Service.Views.AddClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление клиента" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="2" Color="#888888"/>
    </Window.Effect>

    <Border Background="{StaticResource WindowBackgroundBrush}" 
            CornerRadius="15" 
            Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок окна -->
            <Border Grid.Row="0" 
                    Background="{StaticResource PrimaryDarkBrush}" 
                    CornerRadius="15,15,0,0" 
                    Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="👥" FontSize="24" Foreground="{StaticResource TealBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="ДОБАВЛЕНИЕ КЛИЕНТА" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="─" 
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="MinimizeButton_Click"/>
                        <Button Content="✕" 
                                Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Контент -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Background="White"
                          Padding="25">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Фамилия (LastName) -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" 
                               VerticalAlignment="Center" Margin="5"
                               Foreground="{StaticResource DarkTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Text="{Binding EditingClient.LastName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="35"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             Padding="5"/>

                    <!-- Имя (FirstName) -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" 
                               VerticalAlignment="Center" Margin="5"
                               Foreground="{StaticResource DarkTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding EditingClient.FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="35"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             Padding="5"/>

                    <!-- Контактный номер (ContactNumber) -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" 
                               VerticalAlignment="Center" Margin="5"
                               Foreground="{StaticResource DarkTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="2" Grid.Column="1" 
                             Text="{Binding EditingClient.ContactNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="35"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             Padding="5"/>

                    <!-- Скидка (Discount) -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Скидка (%):" 
                               VerticalAlignment="Center" Margin="5"
                               Foreground="{StaticResource DarkTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="3" Grid.Column="1" 
                             Text="{Binding EditingClient.Discount, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="35"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             Padding="5"/>

                    <!-- Информация о автомобилях (нередактируемое поле, только для информации) -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Автомобили:" 
                               VerticalAlignment="Center" Margin="5"
                               Foreground="{StaticResource DarkTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" 
                               Text="{Binding ClientCarsCount, FallbackValue='Нет автомобилей'}"
                               Margin="5" 
                               VerticalAlignment="Center"
                               Foreground="{StaticResource LightTextBrush}"
                               FontStyle="Italic"/>
                </Grid>
            </ScrollViewer>

            <!-- Нижняя панель с кнопками -->
            <Border Grid.Row="2" 
                    Background="{StaticResource LightBackgroundBrush}" 
                    CornerRadius="0,0,15,15" 
                    Padding="20,15"
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" 
                            Width="100" Height="40" 
                            Margin="5"
                            Background="{StaticResource SuccessBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="Отмена" 
                            Width="100" Height="40" 
                            Margin="5"
                            Background="{StaticResource LightBackgroundBrush}"
                            Foreground="{StaticResource DarkTextBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>