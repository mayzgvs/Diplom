<Window x:Class="Service.Views.AddConsumablesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление расходного материала" Height="396" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="15" Margin="5,5,5,10">
        <Grid Margin="0,0,0,43">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#2C3E50" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔩" FontSize="22" Foreground="#E67E22" Margin="0,0,10,0"/>
                        <TextBlock Text="Добавление расходного материала" FontSize="20" FontWeight="Light" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="30,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- для пояснения -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Наименование -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="#2C3E50" FontSize="15">
                        Наименование <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="1,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxOrange}"
                             Text="{Binding EditingConsumable.Name, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите наименование"/>

                    <!-- Категория -->
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Категория <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding ConsumableCategories}"
                              SelectedValue="{Binding EditingConsumable.ConsumableCategoryId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              Text="{Binding SearchCategoryText, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Начните вводить для поиска категории"/>

                    <!-- Стоимость -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Стоимость" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxCostOrange}"
                             Text="{Binding EditingConsumable.Cost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                             Tag="Введите стоимость (например: 1500.00)"
                             ToolTip="Введите стоимость расходника (необязательно)"/>

                    <!-- Пояснение -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                               Margin="5,20,5,5"
                               FontSize="13"
                               Foreground="#7F8C8E"
                               Text="* — обязательное для заполнения поле"/>
                </Grid>
            </ScrollViewer>

            <!-- Нижняя панель -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,15,15" Padding="20,15" Margin="0,0,0,-42">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Height="38" Margin="5"
                            Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="#E67E22"
                            Foreground="White"
                            FontSize="13"
                            Cursor="Hand"
                            ToolTip="Сохранить материал"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>