<Window x:Class="Service.Views.AddEmployeeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление сотрудника" Height="409" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="15" Margin="5,5,5,10">
        <Grid Margin="0,0,0,43">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👨‍🔧" FontSize="22" Foreground="#2980B9" Margin="0,0,10,0"/>
                        <TextBlock Text="Добавление сотрудника" FontSize="20" FontWeight="Light" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="30,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- пояснение -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Фамилия -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Фамилия <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxTeal}"
                             Text="{Binding EditingEmployee.LastName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите фамилию (например: Петров)"/>

                    <!-- Имя -->
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Имя <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxTeal}"
                             Text="{Binding EditingEmployee.FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите имя (например: Иван)"/>

                    <!-- Телефон -->
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Телефон <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxTeal}"
                             Text="{Binding EditingEmployee.ContactNumber, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Формат: +7 (999) 123-45-67"/>

                    <!-- Пояснение -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                               Margin="5,20,5,5"
                               FontSize="13"
                               Foreground="#7F8C8E"
                               Text="* — обязательное для заполнения поле"/>
                </Grid>
            </ScrollViewer>

            <!-- Нижняя панель -->
            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}" CornerRadius="0,0,15,15" Padding="20,15" Margin="0,0,0,-42">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Height="38" Margin="5"
                            Command="{Binding SaveCommand}"
                            Background="#2980B9"
                            Foreground="White"
                            FontSize="13"
                            Cursor="Hand"
                            ToolTip="Сохранить сотрудника"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>