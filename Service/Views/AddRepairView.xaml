<Window x:Class="Service.Views.AddRepairView"
        xmlns:local="clr-namespace:Service.Utility"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание заявки на ремонт" Height="580" Width="650"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="15" Margin="5,5,5,10">
        <Grid Margin="0,0,0,43">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок окна -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="22" Foreground="#27AE60" Margin="0,0,10,0"/>
                        <TextBlock Text="Новая заявка на ремонт" FontSize="20" FontWeight="Light" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="30,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Автомобиль -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Автомобиль" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <Grid Grid.Row="0" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  Style="{StaticResource ModernComboBoxGreen}"
                                  ItemsSource="{Binding Cars}"
                                  SelectedValue="{Binding EditingRepairRequest.CarId, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="RegistrationNumber"/>
                        <Button Grid.Column="1"
                                Content="+"
                                Width="38"
                                Height="38"
                                Margin="8,5,5,5"
                                Command="{Binding AddNewCarCommand}"
                                Background="#27AE60"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Клиент -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource ModernTextBoxGreen}"
                             Text="{Binding ClientName}"
                             IsReadOnly="True"
                             Background="#F8F9FA"
                             IsEnabled="False"/>

                    <!-- Дата начала -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата начала" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <DatePicker Grid.Row="2" Grid.Column="1"
                                Style="{StaticResource ModernDatePickerGreen}"
                                SelectedDate="{Binding EditingRepairRequest.StartDate}"
                                Margin="5" Height="38"/>

                    <!-- Дата окончания -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата окончания" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <DatePicker Grid.Row="3" Grid.Column="1"
                                Style="{StaticResource ModernDatePickerGreen}"
                                SelectedDate="{Binding EditingRepairRequest.EndDate}"
                                Margin="5" Height="38"/>

                    <!-- Блок ошибки дат -->
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{Binding DateError}"
                               Foreground="Red"
                               FontSize="12"
                               Margin="5,2,5,10"
                               TextWrapping="Wrap"/>

                    <!-- Услуга -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Услуга" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <ComboBox Grid.Row="5" Grid.Column="1"
                              Style="{StaticResource ModernComboBoxGreen}"
                              ItemsSource="{Binding Services}"
                              SelectedItem="{Binding SelectedService, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="Name"/>

                    <!-- Стоимость -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Стоимость" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <TextBox Grid.Row="6" Grid.Column="1" 
                             Style="{StaticResource ModernTextBoxGreen}" 
                             Text="{Binding EditingRepairRequest.TotalCost, StringFormat={}{0:N0} ₽}"
                             IsReadOnly="True"
                             Background="#F8F9FA"
                             IsEnabled="False"/>

                    <!-- Статус -->
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Статус" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15"/>
                    <ComboBox Grid.Row="7" Grid.Column="1"
                              Style="{StaticResource ModernComboBoxGreen}"
                              ItemsSource="{Binding Statuses}"
                              SelectedValue="{Binding EditingRepairRequest.StatusId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"/>

                </Grid>
            </ScrollViewer>

            <!-- Кнопки внизу -->
            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}" CornerRadius="0,0,15,15" Padding="20,15" Margin="0,0,0,-42">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Height="38" Margin="5"
                            Command="{Binding SaveCommand}"
                            Background="#27AE60"
                            Foreground="White"
                            FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>