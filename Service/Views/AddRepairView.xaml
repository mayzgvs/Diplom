<Window x:Class="Service.Views.AddRepairView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание заявки на ремонт" Height="650" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundBrush}" CornerRadius="15" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="24" Foreground="{StaticResource TealBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="НОВАЯ ЗАЯВКА НА РЕМОНТ" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Автомобиль:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                    <Grid Grid.Row="0" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Cars}"
                                  SelectedValue="{Binding EditingRepairRequest.CarId, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="RegistrationNumber"
                                  Height="35"/>
                        <Button Grid.Column="1" Content="➕" Width="40" Height="35" Margin="8,0,0,0"
                                Command="{Binding AddNewCarCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditingRepairRequest.Client, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="35"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата начала:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding EditingRepairRequest.StartDate}"
                                Margin="5" Height="35"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                    <ComboBox Grid.Row="3" Grid.Column="1"
                              ItemsSource="{Binding Statuses}"
                              SelectedValue="{Binding EditingRepairRequest.StatusId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Height="35" Margin="5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Стоимость:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditingRepairRequest.TotalCost, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="35"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата окончания:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                    <DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding EditingRepairRequest.EndDate}"
                                Margin="5" Height="35"/>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}" CornerRadius="0,0,15,15" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="110" Height="40" Margin="5" Command="{Binding SaveCommand}"
                            Background="{StaticResource SuccessBrush}" Foreground="White"/>
                    <Button Content="Отмена" Width="110" Height="40" Margin="5" Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>