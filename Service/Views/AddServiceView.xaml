<Window x:Class="Service.Views.AddServiceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление услуги" Height="399" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="15" Margin="5,5,5,10">
        <Grid Margin="0,0,0,43">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="22" Foreground="#9B59B6" Margin="0,0,10,0"/>
                        <TextBlock Text="Добавление услуги" FontSize="20" FontWeight="Light" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="30,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- пояснение -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Название -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Название <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxPurple}"
                             Text="{Binding EditingService.Name, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Введите название услуги"/>

                    <!-- Стоимость -->
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Стоимость <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource WatermarkTextBoxPurple}"
                             Text="{Binding EditingService.Cost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                             Tag="Введите стоимость (например: 1500.00)"
                             ToolTip="Введите стоимость расходника"/>

                    <!-- Категория -->
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5" Foreground="#2C3E50" FontSize="15">
                        Категория <TextBlock Text="*" Foreground="#E74C3C" FontWeight="Bold" Margin="2,0,0,0"/>
                    </TextBlock>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              Style="{StaticResource ModernComboBoxGreen}"
                              ItemsSource="{Binding ServiceCategories}"
                              SelectedValue="{Binding EditingService.ServiceCategoryId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              ToolTip="Выберите категорию услуги"/>

                    <!-- Пояснение -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                               Margin="5,20,5,5"
                               FontSize="13"
                               Foreground="#7F8C8E"
                               Text="* — обязательное для заполнения поле"/>
                </Grid>
            </ScrollViewer>

            <!-- Нижняя панель -->
            <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}" CornerRadius="0,0,15,15" Padding="20,15" Margin="0,0,0,-42">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Height="38" Margin="5"
                            Command="{Binding SaveCommand}"
                            Background="#9B59B6"
                            Foreground="White"
                            FontSize="13"
                            Cursor="Hand"
                            ToolTip="Сохранить услугу"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>