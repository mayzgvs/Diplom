<Window x:Class="Service.Views.AddWorkItemView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="550" Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="White" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🔧" FontSize="24" Foreground="#9B59B6" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="✖" Width="35" Height="35"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="16" Cursor="Hand"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
                <StackPanel>
                    <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Информация о заявке" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Автомобиль:" Foreground="#7F8C8D" Margin="0,5,10,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RepairRequestInfo}" Foreground="#2C3E50" Margin="0,5,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" Foreground="#7F8C8D" Margin="0,5,10,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientInfo}" Foreground="#2C3E50" Margin="0,5,0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Тип работы" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <CheckBox Content="Услуга" IsChecked="{Binding IsServiceSelected}"
                                  Margin="0,0,20,0" FontSize="13"/>
                        <CheckBox Content="Расходный материал" IsChecked="{Binding IsConsumableSelected}"
                                  FontSize="13"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServiceSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Услуга" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Services}"
                                  SelectedItem="{Binding SelectedService}"
                                  DisplayMemberPath="Name"
                                  Height="35"
                                  Margin="0,0,0,20"
                                  BorderBrush="#E0E0E0"
                                  BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConsumableSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Расходный материал" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Consumables}"
                                  SelectedItem="{Binding SelectedConsumable}"
                                  DisplayMemberPath="Name"
                                  Height="35"
                                  Margin="0,0,0,20"
                                  BorderBrush="#E0E0E0"
                                  BorderThickness="1"/>
                    </StackPanel>

                    <TextBlock Text="Сотрудник" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee}"
                              DisplayMemberPath="FullName"
                              Height="35"
                              Margin="0,0,0,20"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"/>

                    <TextBlock Text="Стоимость" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Cost, StringFormat={}{0:N0} ₽}" 
                               Height="35" 
                               Padding="10,8"
                               Background="#F8F9FA"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Статус" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding WorkStatuses}"
                              SelectedItem="{Binding SelectedStatus}"
                              DisplayMemberPath="Name"
                              Height="35"
                              Margin="0,0,0,20"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"/>

                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#E74C3C" 
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" CornerRadius="0,0,15,15" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" 
                            Width="100" Height="35"
                            Background="White"
                            Foreground="#7F8C8D"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            Click="CancelButton_Click"/>
                    <Button Content="Сохранить" 
                            Width="100" Height="35"
                            Background="#9B59B6"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>