<Window x:Class="Service.Views.AddWorkItemView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка на работу"
        Width="550" Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="White" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔧" FontSize="24" Foreground="#9B59B6" Margin="0,0,12,0"/>
                        <TextBlock Text="Добавление работы" FontSize="20" FontWeight="Light" Foreground="White" VerticalAlignment="Center" Width="450"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="35" Height="35"/>
                        <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Width="35" Height="35"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
                <StackPanel>
                    <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Информация о заявке" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Автомобиль:" Foreground="#7F8C8D" Margin="0,5,10,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RepairRequestInfo}" Foreground="#2C3E50" Margin="0,5,0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" Foreground="#7F8C8D" Margin="0,5,10,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientInfo}" Foreground="#2C3E50" Margin="0,5,0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Тип работы" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <CheckBox Content="Услуга" IsChecked="{Binding IsServiceSelected}"
                                  Margin="0,0,20,0" FontSize="13"/>
                        <CheckBox Content="Расходный материал" IsChecked="{Binding IsConsumableSelected}"
                                  FontSize="13"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServiceSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Услуга" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding Services}"
                                  SelectedItem="{Binding SelectedService, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Name"
                                  IsTextSearchEnabled="True"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConsumableSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Расходный материал" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding Consumables}"
                                  SelectedItem="{Binding SelectedConsumable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Name"
                                  IsTextSearchEnabled="True"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"/>
                    </StackPanel>

                    <TextBlock Text="Сотрудник" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="FullName"
                              IsTextSearchEnabled="True"
                              IsEditable="True"
                              StaysOpenOnEdit="True"
                              Margin="0,0,0,20"
                              ToolTip="Выберите сотрудника из списка"/>

                    <TextBlock Text="Стоимость" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <Border Background="#F8F9FA" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20">
                        <TextBlock Text="{Binding DisplayCost}"
                                   Height="35"
                                   Padding="10,8"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FF6B6B"/>
                    </Border>

                    <TextBlock Text="Статус" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding WorkStatuses}"
                              SelectedItem="{Binding SelectedStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="Name"
                              IsTextSearchEnabled="True"
                              IsEditable="True"
                              StaysOpenOnEdit="True"
                              Margin="0,0,0,20"
                              ToolTip="Выберите статус из списка"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" CornerRadius="0,0,15,15" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить"
                            Width="100" Height="35"
                            Background="#9B59B6"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Сохранить работу"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>