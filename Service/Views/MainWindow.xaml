<Window x:Class="Service.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Service.ViewModels"
        xmlns:views="clr-namespace:Service.Views"
        Title="Автосервис: управление сервисом"
        Width="1300" Height="889"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="White" CornerRadius="15" Margin="5"
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2C3E50" CornerRadius="15,15,0,0" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#1ABC9C" CornerRadius="12" Width="44" Height="44" Margin="0,0,15,0">
                            <TextBlock Text="🔧" FontSize="28" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="АВТОСЕРВИС" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="профессиональное обслуживание" FontSize="12" Foreground="#BDC3C7" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Сегодня: " Style="{StaticResource DateTimeStyle}"/>
                        <TextBlock Text="{Binding CurrentDate}" Style="{StaticResource DateTimeStyle}" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding CurrentTime}" Style="{StaticResource TimeStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="MinimizeButton" Content="─" Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="MaximizeButton" Content="□" Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="CloseButton" Style="{StaticResource CloseButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Меню -->
                <Border Grid.Column="0" Background="White" CornerRadius="0,0,0,15">
                    <Border BorderThickness="0,0,1,0" BorderBrush="#F0F0F0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="15,20,15,20">

                                <TextBlock Text="ОСНОВНОЕ" Style="{StaticResource MenuSectionHeaderStyle}"/>

                                <Button Tag="WorkItems" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="WorkItems">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#FF6B6B">
                                            <TextBlock Text="🔧" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Рабочие операции" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление работами" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <TextBlock Text="НАВИГАЦИЯ" Style="{StaticResource MenuSectionHeaderStyle}" Margin="12,20,12,8"/>

                                <Button Tag="Clients" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Clients">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#3498DB">
                                            <TextBlock Text="👥" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Клиенты" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление клиентами" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Tag="Cars" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Cars">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#E67E22">
                                            <TextBlock Text="🚗" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Автомобили" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление автомобилями" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Tag="RepairRequests" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="RepairRequests">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#27AE60">
                                            <TextBlock Text="📋" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Заявки" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление заявками на ремонт" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Tag="Services" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Services">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#9B59B6">
                                            <TextBlock Text="⚙️" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Услуги" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление услугами" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Tag="Consumables" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Consumables">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#E67E22">
                                            <TextBlock Text="🔩" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Расходники" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление расходными материалами" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Tag="Employees" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Employees">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#1ABC9C">
                                            <TextBlock Text="👨‍🔧" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Сотрудники" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Управление сотрудниками" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Border Height="1" Background="#F0F0F0" Margin="12,15,12,15"/>

                                <Button Tag="Reports" Style="{StaticResource NavigationMenuButtonStyle}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Reports">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource MenuIconStyle}" Background="#E74C3C">
                                            <TextBlock Text="📊" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Отчёты" Style="{StaticResource MenuItemTitleStyle}"/>
                                            <TextBlock Text="Аналитика и статистика" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Border>

                <Grid Grid.Column="1" Background="White">
                    <ContentControl Content="{Binding Navigation.CurrentViewModel}">
                        <ContentControl.Resources>
                            <DataTemplate x:Key="WelcomeTemplate">
                                <Grid Background="White">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" 
                                               Text="🔧" 
                                               Style="{StaticResource WelcomeIconStyle}"/>

                                    <TextBlock Grid.Row="1" 
                                               Text="Добро пожаловать в систему управления автосервисом" 
                                               Style="{StaticResource WelcomeTitleStyle}"/>

                                    <TextBlock Grid.Row="2" 
                                               Text="Выберите раздел в меню слева для начала работы" 
                                               Style="{StaticResource WelcomeSubtitleStyle}"/>
                                </Grid>
                            </DataTemplate>

                            <DataTemplate DataType="{x:Type viewModels:WorkItemViewModel}">
                                <views:WorkItemView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ClientViewModel}">
                                <views:ClientView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:CarViewModel}">
                                <views:CarView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:RepairRequestViewModel}">
                                <views:RepairView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ServiceViewModel}">
                                <views:ServiceView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ConsumableViewModel}">
                                <views:ConsumablesView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:EmployeeViewModel}">
                                <views:EmployeeView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
                                <views:ReportView/>
                            </DataTemplate>
                        </ContentControl.Resources>

                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Navigation.CurrentViewModel}" Value="{x:Null}">
                                        <Setter Property="ContentTemplate" Value="{StaticResource WelcomeTemplate}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>