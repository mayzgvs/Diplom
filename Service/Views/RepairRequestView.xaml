<UserControl x:Class="Service.Views.RepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Service.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,10">
            <TextBlock Text="Управление заявками на ремонт" 
                       FontSize="28" 
                       FontWeight="Light" 
                       Foreground="{StaticResource DarkTextBrush}"
                       Margin="0,0,0,15"/>
        </StackPanel>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="15"
                Margin="20,0,20,15"
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Background="{StaticResource LightBackgroundBrush}" 
                        CornerRadius="5" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1"
                        Height="35"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="🔍" 
                                   Margin="10,0" 
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource LightTextBrush}"/>

                        <TextBox Grid.Column="1" 
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 VerticalAlignment="Center"
                                 ToolTip="Введите номер авто, VIN или ФИО клиента"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Grid.Column="2"
                                Content="✖"
                                Width="25"
                                Height="25"
                                Margin="0,0,5,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource LightTextBrush}"
                                FontSize="14"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Command="{Binding ClearSearchCommand}"
                                ToolTip="Очистить поиск"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal"
                            Margin="0,0,10,0">

                    <Border Background="{StaticResource LightBackgroundBrush}" 
                            CornerRadius="5" 
                            BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="1"
                            Height="35"
                            Width="150">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="⚡" 
                                       Margin="10,0" 
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource LightTextBrush}"/>

                            <ComboBox Grid.Column="1"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ItemsSource="{Binding Statuses}"
                                      SelectedItem="{Binding SelectedStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                      ToolTip="Фильтр по статусу"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="3">
                                            <Border Width="10" Height="10" 
                                                    CornerRadius="2"
                                                    Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Name}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ListView Grid.Row="2" 
                  Margin="20,0,20,20"
                  ItemsSource="{Binding FilteredRequests}"
                  SelectedItem="{Binding CurrentRequest, Mode=TwoWay}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Background="White"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="№" Width="50" 
                                    DisplayMemberBinding="{Binding Id}"/>

                    <GridViewColumn Header="Автомобиль" Width="120" 
                                    DisplayMemberBinding="{Binding Car.RegistrationNumber}"/>

                    <GridViewColumn Header="Марка/Модель" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Car.Brand}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Клиент" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Client.FullName}" 
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Client.Phone}" 
                                               FontSize="11"
                                               Foreground="{StaticResource LightTextBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Начало" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StartDate, StringFormat='dd.MM.yyyy'}"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Окончание" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EndDate, StringFormat='dd.MM.yyyy'}"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Статус" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="5,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFF0F0F0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.Name}" Value="Завершен">
                                                    <Setter Property="Background" Value="#FFFFE6E6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status.Name}" Value="В процессе">
                                                    <Setter Property="Background" Value="#FFE6FFE6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status.Name}" Value="Ожидает">
                                                    <Setter Property="Background" Value="#FFFFF0E6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" 
                            CornerRadius="4"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Gray"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status.Name}" Value="Завершен">
                                                            <Setter Property="Background" Value="Red"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status.Name}" Value="В процессе">
                                                            <Setter Property="Background" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status.Name}" Value="Ожидает">
                                                            <Setter Property="Background" Value="Orange"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <TextBlock Text="{Binding Status.Name}" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status.Name}" Value="Завершен">
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status.Name}" Value="В процессе">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status.Name}" Value="Ожидает">
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Сумма" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TotalCost, StringFormat={}{0:C2}}" 
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Механик" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Mechanic.FullName}"
                                           Foreground="{StaticResource LightTextBrush}"
                                           FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="MinHeight" Value="55"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Border Grid.Row="3" 
                Background="White" 
                CornerRadius="8" 
                Padding="15"
                Margin="20,0,20,20"
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="➕ Создать заявку"
                        Style="{StaticResource AddButtonWithIconStyle}" 
                        Width="140" 
                        Margin="0,0,10,0" 
                        Command="{Binding AddCommand}"/>
                <Button Content="✏️ Редактировать"
                        Style="{StaticResource EditButtonWithIconStyle}" 
                        Width="140" 
                        Margin="0,0,10,0" 
                        Command="{Binding EditCommand}"/>
                <Button Content="📋 Детали"
                        Style="{StaticResource CancelButtonStyle}" 
                        Width="120" 
                        Margin="0,0,10,0" 
                        Command="{Binding ViewDetailsCommand}"/>
                <Button Content="🗑️ Удалить"
                        Style="{StaticResource DeleteButtonWithIconStyle}" 
                        Width="100" 
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>