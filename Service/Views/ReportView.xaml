<UserControl x:Class="Service.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Service.ViewModels"
             xmlns:conv="clr-namespace:Service.Utility"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1280"
             Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25">

            <!-- ХЕДЕР -->
            <Border Background="{StaticResource HeaderGradient}" CornerRadius="20" Padding="30,25" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="📊 ОТЧЁТЫ И АНАЛИТИКА" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Полная статистика работы автосервиса" FontSize="14" Foreground="#BDC3C7" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- ПЕРИОД ОТЧЁТА -->
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📅 ПЕРИОД ОТЧЁТА" Style="{StaticResource MenuSectionHeaderStyle}" Margin="0,0,0,15"/>
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding StartDate}" Width="140" Height="36" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Width="140" Height="36" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="Быстрый выбор:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding PeriodPresets}" 
                                      SelectedItem="{Binding PeriodPreset}" 
                                      Width="120" Height="36" 
                                      Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- МЕТРИКИ -->
            <WrapPanel Margin="0,0,0,20">
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="28" Foreground="{StaticResource TealBrush}"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.TotalRevenue, StringFormat={}{0:N0} ₽}" 
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Общая выручка" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="28" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.TotalRequests}" 
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Всего заявок" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="⭐" FontSize="28" Foreground="{StaticResource PurpleBrush}"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.AverageRequestValue, StringFormat={}{0:N0} ₽}" 
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Средний чек" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="📈" FontSize="28" Foreground="{StaticResource OrangeBrush}"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.AverageRevenuePerDay, StringFormat={}{0:N0} ₽}" 
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Выручка в день" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- КНОПКИ ЭКСПОРТА -->
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📎 ЭКСПОРТ ОТЧЁТОВ" Style="{StaticResource MenuSectionHeaderStyle}" Margin="0,0,0,15"/>

                    <!-- Ряд 1: Финансовые отчёты -->
                    <WrapPanel>
                        <Button Content="💰 Отчёт по выручке (Excel)" Command="{Binding ExportRevenueToExcelCommand}" Style="{StaticResource ExcelButtonStyle}"/>
                        <Button Content="📄 Отчёт по выручке (Word)" Command="{Binding ExportRevenueToWordCommand}" Style="{StaticResource WordButtonStyle}"/>
                        <Button Content="📋 Детальный отчёт (Excel)" Command="{Binding ExportDetailedToExcelCommand}" Style="{StaticResource ExcelButtonStyle}"/>
                    </WrapPanel>

                    <!-- Ряд 2: Отчёты по ресурсам -->
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="🚗 Отчёт по автомобилям (Excel)" Command="{Binding ExportVehiclesReportCommand}" Style="{StaticResource ExcelButtonStyle}"/>
                        <Button Content="👨‍🔧 Отчёт по сотрудникам (Excel)" Command="{Binding ExportEmployeesReportCommand}" Style="{StaticResource ExcelButtonStyle}"/>
                    </WrapPanel>

                    <!-- Ряд 3: Формирование документа -->
                    <WrapPanel Margin="0,10,0,0">
                        <StackPanel>
                            <Button Content="📄 Заказ-наряд (Excel)*" 
                                    Command="{Binding ExportSingleRequestToExcelCommand}" 
                                    Style="{StaticResource ExcelButtonStyle}"
                                    IsEnabled="{Binding CanExportSingleRequest}"/>
                            <TextBlock Text="* выберите заявку в списке ниже" 
                                       VerticalAlignment="Center" 
                                       Foreground="{StaticResource LightTextBrush}" 
                                       FontSize="10"
                                       Margin="10,2,0,0"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ТАБЛИЦА ЗАЯВОК -->
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📋 СПИСОК ЗАЯВОК" Style="{StaticResource MenuSectionHeaderStyle}" Margin="0,0,0,15"/>

                    <!-- ПОИСК -->
                    <WrapPanel Margin="0,0,0,15" Width="789">
                        <Border Background="{StaticResource LightBackgroundBrush}" CornerRadius="8" Padding="10,5" Margin="0,0,10,5" Width="770">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="30" BorderThickness="0" Background="Transparent"
                                         Foreground="{StaticResource DarkTextBrush}" FontSize="15" Width="770" VerticalContentAlignment="Center"> 
                                </TextBox>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- DataGrid с вертикальной прокруткой -->
                    <DataGrid ItemsSource="{Binding FilteredRequests}" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectedItem="{Binding SelectedRequest}"
                  BorderThickness="1" BorderBrush="#EDEDED"
                  RowHeight="45" HeadersVisibility="Column"
                  AlternatingRowBackground="#FAFBFC"
                  FontSize="12"
                  MaxHeight="400"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EBF5FB"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding RequestId}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="180"/>
                            <DataGridTextColumn Header="Автомобиль" Binding="{Binding CarInfo}" Width="200"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTemplateColumn Header="Статус" Width="110" CellTemplate="{StaticResource StatusTemplate}"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalCost, StringFormat={}{0:N2} ₽}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource TealBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ТОП-5 УСЛУГ -->
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🏆 ТОП-5 УСЛУГ ПО ВЫРУЧКЕ" Style="{StaticResource MenuSectionHeaderStyle}" Margin="0,0,0,15"/>
                    <ItemsControl ItemsSource="{Binding CurrentRevenueReport.TopServices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDEDED" BorderThickness="0,0,0,1" Padding="10,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ServiceName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count, StringFormat={}{0} раз(а)}" FontSize="12" Foreground="{StaticResource LightTextBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Revenue, StringFormat={}{0:N0} ₽}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TealBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ТОП-5 СОТРУДНИКОВ -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="👨‍🔧 ТОП-5 СОТРУДНИКОВ ПО ВЫРУЧКЕ" Style="{StaticResource MenuSectionHeaderStyle}" Margin="0,0,0,15"/>
                    <ItemsControl ItemsSource="{Binding CurrentRevenueReport.TopEmployees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDEDED" BorderThickness="0,0,0,1" Padding="10,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" FontWeight="Bold" Foreground="{StaticResource PurpleBrush}" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EmployeeName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CompletedJobs}" FontSize="12" Foreground="{StaticResource LightTextBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding TotalRevenue, StringFormat={}{0:N0} ₽}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TealBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>