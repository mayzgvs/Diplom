<UserControl x:Class="Service.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Service.ViewModels"
             xmlns:conv="clr-namespace:Service.Utility"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1280"
             Background="#F0F2F5">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2C3E50" Offset="0"/>
            <GradientStop Color="#3498DB" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E67E22"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D35400"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3498DB"/>
            <Setter Property="BorderBrush" Value="#3498DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <DataTemplate x:Key="StatusTemplate">
            <Border CornerRadius="12" Padding="8,4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Завершённые">
                                <Setter Property="Background" Value="#D5F5E3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="В работе">
                                <Setter Property="Background" Value="#EBF5FB"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Новые">
                                <Setter Property="Background" Value="#FEF9E7"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Отменённые">
                                <Setter Property="Background" Value="#FDEDEC"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Завершённые">
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="В работе">
                                    <Setter Property="Foreground" Value="#2980B9"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Новые">
                                    <Setter Property="Foreground" Value="#F39C12"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Отменённые">
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25">

            <Border Background="{StaticResource HeaderGradient}" CornerRadius="20" Padding="30,25" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="📊 ОТЧЁТЫ И АНАЛИТИКА" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Полная статистика работы автосервиса" FontSize="14" Foreground="#BDC3C7" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📅 ПЕРИОД ОТЧЁТА" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding StartDate}" Width="140" Height="36" BorderBrush="#E0E0E0" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Width="140" Height="36" BorderBrush="#E0E0E0" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="Быстрый выбор:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding PeriodPresets}" 
                                      SelectedItem="{Binding PeriodPreset}" 
                                      Width="120" Height="36">
                            </ComboBox>
                        </StackPanel>
                        <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <WrapPanel Margin="0,0,0,20">
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="28" Foreground="#27AE60"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.TotalRevenue, StringFormat={}{0:N0} ₽}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                        <TextBlock Text="Общая выручка" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="28" Foreground="#3498DB"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.TotalRequests}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                        <TextBlock Text="Всего заявок" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="⭐" FontSize="28" Foreground="#9B59B6"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.AverageRequestValue, StringFormat={}{0:N0} ₽}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                        <TextBlock Text="Средний чек" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="220">
                    <StackPanel>
                        <TextBlock Text="📈" FontSize="28" Foreground="#E67E22"/>
                        <TextBlock Text="{Binding CurrentRevenueReport.AverageRevenuePerDay, StringFormat={}{0:N0} ₽}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                        <TextBlock Text="Выручка в день" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📎 ЭКСПОРТ ОТЧЁТОВ" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    <WrapPanel>
                        <Button Content="💰 Отчёт по выручке (Excel)" Command="{Binding ExportRevenueToExcelCommand}" Style="{StaticResource SuccessButtonStyle}"/>
                        <Button Content="📄 Отчёт по выручке (Word)" Command="{Binding ExportRevenueToWordCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="📋 Детальный отчёт (Excel)" Command="{Binding ExportDetailedToExcelCommand}" Style="{StaticResource SuccessButtonStyle}"/>
                    </WrapPanel>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="🚗 Отчёт по автомобилям (Excel)" Command="{Binding ExportVehiclesReportCommand}" Style="{StaticResource WarningButtonStyle}"/>
                        <Button Content="👨‍🔧 Отчёт по сотрудникам (Excel)" Command="{Binding ExportEmployeesReportCommand}" Style="{StaticResource WarningButtonStyle}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📋 СПИСОК ЗАЯВОК" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,15"/>

                    <WrapPanel Margin="0,0,0,15" Width="789">
                        <Border Background="#F5F5F5" CornerRadius="8" Padding="10,5" Margin="0,0,10,5" Width="774">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="30" BorderThickness="0" Background="Transparent"
                                         Foreground="#2C3E50" FontSize="12">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBox x:Name="PART_TextBox" Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}"
                                                                     BorderThickness="0" Background="Transparent"/>
                                                            <TextBlock Text="Поиск по №, клиенту, автомобилю" IsHitTestVisible="False" Foreground="#95A5A6" 
                                                                       VerticalAlignment="Center" Margin="5,0,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, ElementName=PART_TextBox}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <DataGrid ItemsSource="{Binding FilteredRequests}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectedItem="{Binding SelectedRequest}"
                              BorderThickness="1" BorderBrush="#EDEDED"
                              RowHeight="45" HeadersVisibility="Column"
                              AlternatingRowBackground="#FAFBFC"
                              FontSize="12">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EBF5FB"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding RequestId}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#3498DB"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="180"/>
                            <DataGridTextColumn Header="Автомобиль" Binding="{Binding CarInfo}" Width="200"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTemplateColumn Header="Статус" Width="110" CellTemplate="{StaticResource StatusTemplate}"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalCost, StringFormat={}{0:N2} ₽}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🏆 ТОП-5 УСЛУГ ПО ВЫРУЧКЕ" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    <ItemsControl ItemsSource="{Binding CurrentRevenueReport.TopServices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDEDED" BorderThickness="0,0,0,1" Padding="10,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" FontWeight="Bold" Foreground="#3498DB" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ServiceName}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count, StringFormat={}{0} раз(а)}" FontSize="12" Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Revenue, StringFormat={}{0:N0} ₽}" FontSize="13" FontWeight="Bold" Foreground="#27AE60"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="👨‍🔧 ТОП-5 СОТРУДНИКОВ ПО ВЫРУЧКЕ" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    <ItemsControl ItemsSource="{Binding CurrentRevenueReport.TopEmployees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDEDED" BorderThickness="0,0,0,1" Padding="10,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" FontWeight="Bold" Foreground="#9B59B6" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EmployeeName}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CompletedJobs}" FontSize="12" Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="3" Text="{Binding TotalRevenue, StringFormat={}{0:N0} ₽}" FontSize="13" FontWeight="Bold" Foreground="#27AE60"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>