<UserControl x:Class="Service.Views.ServiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙️" FontSize="28" Foreground="#9B59B6" Margin="0,0,12,0"/>
                <TextBlock Text="Управление услугами" Style="{StaticResource PageTitleStyle}" Margin="0"/>
            </StackPanel>
            <TextBlock Text="Просмотр, добавление и редактирование услуг автосервиса"
                       FontSize="13" Foreground="#7F8C8D" Margin="40,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource SearchPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource LightBackgroundBrush}" CornerRadius="5"
                        BorderBrush="#E0E0E0" BorderThickness="1" Height="38" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Margin="12,0" VerticalAlignment="Center" Foreground="#95A5A6" FontSize="14"/>
                        <TextBox Grid.Column="1" Style="{StaticResource SearchTextBox}"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Введите наименование услуги"
                                 VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="✖" Width="30" Height="30" Margin="0,0,8,0"
                                Background="Transparent" BorderThickness="0" Foreground="#95A5A6"
                                FontSize="12" Cursor="Hand" Command="{Binding ClearSearchCommand}"
                                ToolTip="Очистить поиск"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ListView Grid.Row="2" Margin="20,0,20,20"
                  ItemsSource="{Binding FilteredServices}"
                  SelectedItem="{Binding SelectedService, Mode=TwoWay}"
                  Background="White" BorderBrush="#E0E0E0" BorderThickness="1" FontFamily="Segoe UI">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="НАИМЕНОВАНИЕ" Width="350">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="НАИМЕНОВАНИЕ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="#2C3E50" FontSize="13" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="КАТЕГОРИЯ" Width="200">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="КАТЕГОРИЯ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ServiceCategory.Name}" Foreground="#2C3E50" FontSize="13" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="СТОИМОСТЬ" Width="150">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СТОИМОСТЬ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Cost, StringFormat={}{0:N0} ₽}"
                                           Style="{StaticResource CostStyle}" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="" Width="100">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="ДЕЙСТВИЯ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="✏️" FontSize="16"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Удалить"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="🗑️" FontSize="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="48"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F3E5F5"/>
                            <Setter Property="BorderBrush" Value="#9B59B6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8F9FA"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15"
                Margin="20,0,20,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="➕ Добавить услугу" Width="140" Height="38"
                        Background="#9B59B6" Foreground="White" FontSize="13"
                        FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding AddCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>