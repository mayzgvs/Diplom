<Window x:Class="Service.Views.SmtpSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utility="clr-namespace:Service.Utility"
        Title="Настройки SMTP"
        Height="520" Width="570"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8F9FA">

    <Window.Resources>
        <!-- Существующий конвертер -->
        <utility:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- Новый конвертер -->
        <utility:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Настройки SMTP-сервера" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <!-- Основная таблица с полями -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Метки -->
            <TextBlock Text="SMTP Сервер:" Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
            <TextBlock Text="Порт:" Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
            <TextBlock Text="Email для входа:" Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
            <TextBlock Text="Пароль:" Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
            <TextBlock Text="Email отправителя (From):" Grid.Row="4" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
            <TextBlock Text="Имя отправителя:" Grid.Row="5" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>

            <!-- Поля ввода -->
            <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="0" Grid.Column="1" Margin="10,5,0,5" Height="30" VerticalContentAlignment="Center"/>

            <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="1" Grid.Column="1" Margin="10,5,0,5" Width="120" HorizontalAlignment="Left" 
                     Height="30" VerticalContentAlignment="Center"/>

            <TextBox Text="{Binding SmtpEmail, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="2" Grid.Column="1" Margin="10,5,0,5" Height="30" VerticalContentAlignment="Center"/>

            <PasswordBox x:Name="pbPassword" 
                         Grid.Row="3" Grid.Column="1" Margin="10,5,0,5" Height="30"
                         PasswordChanged="pbPassword_PasswordChanged"/>

            <TextBox Text="{Binding SmtpFromEmail, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="4" Grid.Column="1" Margin="10,5,0,5" Height="30" VerticalContentAlignment="Center"/>

            <TextBox Text="{Binding SmtpSenderName, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="5" Grid.Column="1" Margin="10,5,0,5" Height="30" VerticalContentAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,25,0,0">
            <CheckBox IsChecked="{Binding SmtpEnableSsl}" Content="Использовать SSL/TLS" Margin="0,6"/>
            <CheckBox IsChecked="{Binding SmtpUseDefaultCredentials}" 
                      Content="Использовать учётные данные Windows (без логина и пароля)" 
                      Margin="0,8,0,5"/>
            <TextBlock Text="• Включайте для корпоративных серверов (Exchange, внутренний relay)" 
                       Foreground="#555" FontSize="12" Margin="25,0,0,0"/>
        </StackPanel>

        <!-- ИСПРАВЛЕННЫЙ БЛОК КНОПОК -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            
            <!-- Индикатор загрузки -->
            <ProgressBar Width="140" Height="28" Margin="0,0,15,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                         IsIndeterminate="True"
                         VerticalAlignment="Center"/>

            <Button Content="Протестировать"
                    Command="{Binding TestCommand}"
                    Width="160" Height="38" Margin="0,0,12,0"
                    Background="#FFFFFF" BorderBrush="#9C27B0" Foreground="#9C27B0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Width="120" Height="38" Margin="0,0,12,0"
                    Background="#9C27B0" Foreground="White" FontWeight="Medium"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
        </StackPanel>
    </Grid>
</Window>