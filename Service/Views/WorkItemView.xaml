<UserControl x:Class="Service.Views.WorkItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Service.Utility"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Utility/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="18"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F0F0F0"/>
                        <Setter Property="Opacity" Value="0.8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Light"/>
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="Margin" Value="0,0,0,20"/>
            </Style>

            <Style x:Key="SearchPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="Margin" Value="20,0,20,20"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="CostStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#27AE60"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <!-- Стиль для тега услуги -->
            <Style x:Key="ServiceTagStyle" TargetType="Border">
                <Setter Property="Background" Value="#E3F2FD"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="0,2"/>
            </Style>

            <!-- Стиль для тега расходника -->
            <Style x:Key="ConsumableTagStyle" TargetType="Border">
                <Setter Property="Background" Value="#FFF3E0"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="0,2"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔧" FontSize="28" Foreground="#FF6B6B" Margin="0,0,12,0"/>
                <TextBlock Text="Рабочие операции" Style="{StaticResource PageTitleStyle}" Margin="0"/>
            </StackPanel>
            <TextBlock Text="Управление работами в рамках заявок на ремонт" 
                       FontSize="13" 
                       Foreground="#7F8C8D" 
                       Margin="40,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource SearchPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Заявка на ремонт:" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,15,0"
                               Foreground="#2C3E50"/>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding RepairRequests}"
                              SelectedItem="{Binding SelectedRepairRequest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="DisplayName"
                              FontSize="13"
                              Height="35"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="10,5"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </Grid>
            </Grid>
        </Border>

        <ListView Grid.Row="3" 
                  Margin="20,0,20,20"
                  ItemsSource="{Binding WorkItems}"
                  SelectedItem="{Binding SelectedWorkItem, Mode=TwoWay}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  FontFamily="Segoe UI">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="УСЛУГА / РАСХОДНЫЙ МАТЕРИАЛ" Width="300">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="УСЛУГА / РАСХОДНЫЙ МАТЕРИАЛ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,5">
                                    <!-- Услуга - исправлено использование конвертера -->
                                    <Border Style="{StaticResource ServiceTagStyle}" 
                                            Visibility="{Binding ServiceName, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔧 " FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ServiceName}" 
                                                       FontSize="12" 
                                                       Foreground="#1565C0"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" (услуга)" 
                                                       FontSize="10" 
                                                       Foreground="#64B5F6"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Расходный материал - исправлено использование конвертера -->
                                    <Border Style="{StaticResource ConsumableTagStyle}" 
                                            Visibility="{Binding ConsumableName, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔩 " FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ConsumableName}" 
                                                       FontSize="12" 
                                                       Foreground="#E65100"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" (расходник)" 
                                                       FontSize="10" 
                                                       Foreground="#FF9800"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="СОТРУДНИК" Width="160">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СОТРУДНИК" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,5">
                                    <TextBlock Text="{Binding EmployeeFullName}" Foreground="#2C3E50" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="СТОИМОСТЬ" Width="120">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СТОИМОСТЬ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Cost, StringFormat={}{0:N0} ₽}" 
                                           Style="{StaticResource CostStyle}"
                                           Padding="8,5"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="СТАТУС" Width="110">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СТАТУС" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="5,2" Margin="5,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#95A5A6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusName}" Value="Новая">
                                                    <Setter Property="Background" Value="#3498DB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusName}" Value="В работе">
                                                    <Setter Property="Background" Value="#F39C12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusName}" Value="Завершена">
                                                    <Setter Property="Background" Value="#27AE60"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusName}" 
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="" Width="100">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="ДЕЙСТВИЯ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}" 
                                            ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="✏️" FontSize="16"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" 
                                            ToolTip="Удалить"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="🗑️" FontSize="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="60"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F3E5F5"/>
                            <Setter Property="BorderBrush" Value="#9B59B6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8F9FA"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Border Grid.Row="4" 
                Background="White" 
                CornerRadius="8" 
                Padding="15" 
                Margin="20,0,20,20"
                BorderBrush="#E0E0E0" 
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="➕ Добавить работу" 
                        Width="140" 
                        Height="38" 
                        Background="#FF6B6B"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsEnabled="{Binding CanAddWorkItem}"
                        Command="{Binding AddCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>