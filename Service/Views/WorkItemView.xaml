<UserControl x:Class="Service.Views.WorkItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Service.Utility"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter"/>

            <DataTemplate x:Key="RepairRequestTemplate">
                <Border Padding="8,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="№" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding Id}" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,10,0" Width="40"/>
                        <TextBlock Text="{Binding Car.Brand}" Foreground="#2C3E50" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding Car.Model}" Foreground="#2C3E50" Margin="0,0,10,0"/>
                        <TextBlock Text="(" Foreground="#95A5A6"/>
                        <TextBlock Text="{Binding Car.RegistrationNumber}" Foreground="#95A5A6"/>
                        <TextBlock Text=")" Foreground="#95A5A6"/>
                        <TextBlock Text=" — " Foreground="#BDC3C7" Margin="5,0"/>
                        <TextBlock Text="{Binding StartDate, StringFormat=dd.MM.yyyy}" Foreground="#7F8C8D" FontSize="11"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔧" FontSize="28" Foreground="#FF6B6B" Margin="0,0,12,0"/>
                <TextBlock Text="Рабочие операции" Style="{StaticResource PageTitleStyle}" Margin="0"/>
            </StackPanel>
            <TextBlock Text="Управление работами в рамках заявок на ремонт"
                       FontSize="13" Foreground="#7F8C8D" Margin="40,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource SearchPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Заявка на ремонт:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,15,0"
                               Foreground="#2C3E50"/>

                    <ComboBox Grid.Column="1"
                              Style="{StaticResource TallComboBoxStyle}"
                              ItemContainerStyle="{StaticResource TallComboBoxItemStyle}"
                              ItemsSource="{Binding RepairRequests}"
                              SelectedItem="{Binding SelectedRepairRequest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ItemTemplate="{StaticResource RepairRequestTemplate}"
                              IsSynchronizedWithCurrentItem="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    </ComboBox>

                    <Button Grid.Column="2"
                            Content="🔄"
                            Width="38"
                            Height="38"
                            Margin="10,0,0,0"
                            Background="#3498DB"
                            Foreground="White"
                            FontSize="16"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Обновить список заявок"
                            Command="{Binding RefreshCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <ListView Grid.Row="3"
                  Margin="20,0,20,20"
                  ItemsSource="{Binding WorkItems}"
                  SelectedItem="{Binding SelectedWorkItem, Mode=TwoWay}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  FontFamily="Segoe UI">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="УСЛУГА / РАСХОДНЫЙ МАТЕРИАЛ" Width="340">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="УСЛУГА / РАСХОДНЫЙ МАТЕРИАЛ"
                                           Foreground="#7F8C8D"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,5" Orientation="Vertical">
                                    <Border Style="{StaticResource ServiceTagStyle}"
                                            Visibility="{Binding ServiceName, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔧" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding ServiceName}"
                                                       FontSize="13"
                                                       Foreground="#1565C0"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource ConsumableTagStyle}"
                                            Visibility="{Binding ConsumableName, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔩" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding ConsumableName}"
                                                       FontSize="13"
                                                       Foreground="#E65100"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource NotSpecifiedTagStyle}"
                                            Visibility="{Binding ServiceName, Converter={StaticResource IsNullOrEmptyConverter}, FallbackValue=Collapsed}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="❌" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="Не указано"
                                                       FontSize="13"
                                                       Foreground="#95A5A6"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="СОТРУДНИК" Width="160">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СОТРУДНИК" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EmployeeFullName}" Foreground="#2C3E50" FontSize="13" Padding="8,5"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="СТОИМОСТЬ" Width="120">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СТОИМОСТЬ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Cost, StringFormat={}{0:N0} ₽}"
                                           Style="{StaticResource FullSumStyle}"
                                           Padding="8,5"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="СТАТУС" Width="110">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="СТАТУС" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="5,2" Margin="5,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#95A5A6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusName}" Value="Новая">
                                                    <Setter Property="Background" Value="#3498DB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusName}" Value="В работе">
                                                    <Setter Property="Background" Value="#F39C12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusName}" Value="Завершена">
                                                    <Setter Property="Background" Value="#27AE60"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusName}" HorizontalAlignment="Center" FontSize="12" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="" Width="100">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="ДЕЙСТВИЯ" Foreground="#7F8C8D" FontSize="12" FontWeight="SemiBold" Padding="8,5" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="✏️" FontSize="16"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            ToolTip="Удалить"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="🗑️" FontSize="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="60"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F3E5F5"/>
                            <Setter Property="BorderBrush" Value="#9B59B6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8F9FA"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Border Grid.Row="4"
                Background="White"
                CornerRadius="8"
                Padding="15"
                Margin="20,0,20,20"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="➕ Добавить работу"
                        Width="140"
                        Height="38"
                        Background="#FF6B6B"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsEnabled="{Binding CanAddWorkItem}"
                        Command="{Binding AddCommand}"/>

                <Button Content="Обновить"
                        Width="100"
                        Height="38"
                        Margin="10,0,0,0"
                        Background="#3498DB"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>